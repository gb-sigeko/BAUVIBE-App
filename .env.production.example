# Kopie nach /opt/bauvibe/app/.env.production auf dem Server (nicht committen).

NODE_ENV=production

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

NEXTAUTH_URL="https://app.example.com"
AUTH_SECRET=""

EMAIL_SERVER="smtp://USER:PASSWORD@HOST:587"
EMAIL_FROM="BAUVIBE <noreply@example.com>"
EMAIL_MOCK="0"

