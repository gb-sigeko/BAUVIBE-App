# Postgres (Supabase Pooler + Direktverbindung für Migrationen)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# NextAuth / Auth.js
NEXTAUTH_URL="http://localhost:3000"
# Mindestens eines setzen:
NEXTAUTH_SECRET=""
AUTH_SECRET=""

# E-Mail (SMTP); für lokale Tests oft Mock
EMAIL_SERVER="smtp://USER:PASSWORD@HOST:587"
EMAIL_FROM="BAUVIBE <noreply@example.com>"
EMAIL_MOCK="1"

# Optional: Resend statt SMTP
# RESEND_API_KEY=""

# Phase 9 – KI (optional, Platzhalter)
# OPENAI_API_KEY=""
# GEMINI_API_KEY=""

# CI: Test-Datenbank für GitHub Actions (lokal nur bei Bedarf)
# TEST_DATABASE_URL=""

# Deployment (Hetzner)
# HETZNER_SERVER_IP=""
# SSH_USER="root"
